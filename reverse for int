class Solution {
    public int reverse(int x) {
        int rev = 0;
        int m = Integer.MIN_VALUE;
        int n = Integer.MAX_VALUE;

        while (x != 0) {
            int d = x % 10;

            if (rev > n / 10 || rev < m / 10) {
                return 0;
            }

            rev = rev * 10 + d;
            x /= 10;
        }

        return rev;
    }
}
